---
import { cta } from '../../data/cta'
import { ArrowRight } from 'lucide-astro'
---

<section id="cta" class="py-24 relative px-6 md:px-12 overflow-hidden">
  <div class="mx-auto max-w-6xl relative rounded-[2.5rem] bg-heading/5 border border-heading/10 shadow-[0_20px_60px_rgb(0,0,0,0.05)] dark:shadow-[0_20px_60px_rgb(0,0,0,0.2)] overflow-hidden">
    
    {/* Grid Background Pattern */}
    <div class="absolute inset-0 bg-[linear-gradient(to_right,rgba(0,0,0,0.05)_1px,transparent_1px),linear-gradient(to_bottom,rgba(0,0,0,0.05)_1px,transparent_1px)] dark:bg-[linear-gradient(to_right,rgba(255,255,255,0.05)_1px,transparent_1px),linear-gradient(to_bottom,rgba(255,255,255,0.05)_1px,transparent_1px)] bg-[size:32px_32px]"></div>

    {/* Glowing Orbs */}
    <div class="absolute top-0 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[500px] bg-secondary/20 rounded-full blur-[120px] pointer-events-none"></div>
    <div class="absolute bottom-0 right-0 w-[400px] h-[400px] bg-accent/20 rounded-full blur-[100px] pointer-events-none translate-y-1/2 translate-x-1/3"></div>

    <div class="relative z-10 px-8 py-24 md:py-32 text-center flex flex-col items-center">
      {/* Badge */}
      <span class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-heading/10 bg-heading/5 backdrop-blur-md text-xs font-semibold uppercase tracking-widest text-heading/80 mb-8">
        <span class="relative flex h-2 w-2">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-secondary opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-secondary"></span>
        </span>
        Ready to Transform?
      </span>

      <h2
        class="text-4xl md:text-5xl lg:text-6xl font-bold font-serif leading-tight max-w-4xl mb-6 text-heading"
        style="white-space: pre-line;"
      >
        {cta.title}
      </h2>
      
      <p class="text-lg md:text-xl text-body mb-12 max-w-2xl leading-relaxed font-medium">
        {cta.subtitle}
      </p>
      
      <div class="flex flex-col sm:flex-row items-center gap-4">
        <a
          href={cta.button.href}
          class="group px-8 py-4 rounded-full bg-secondary hover:bg-secondary/90 text-heading font-bold transition-all duration-300 flex items-center justify-center gap-3 shadow-[0_0_20px_rgba(233,196,106,0.2)] hover:shadow-[0_0_30px_rgba(233,196,106,0.4)] hover:-translate-y-1 w-full sm:w-auto"
        >
          {cta.button.label}
          <div class="bg-heading/10 p-1.5 rounded-full transition-transform duration-300 group-hover:translate-x-1">
            <ArrowRight class="w-4 h-4" strokeWidth="2.5" />
          </div>
        </a>
        <a
          href="mailto:demo@amertarva.app"
          class="px-8 py-4 rounded-full bg-transparent border border-heading/20 text-heading hover:bg-heading/5 font-bold transition-all duration-300 w-full sm:w-auto"
        >
          Request Demo
        </a>
      </div>
      
      <p class="mt-10 text-sm text-body/70 font-medium tracking-wide flex items-center gap-2">
        <svg class="w-4 h-4 text-secondary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
        {cta.note}
      </p>
    </div>
  </div>
</section>
