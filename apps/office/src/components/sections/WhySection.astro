---
import { whyItems } from '../../data/why'
---

<section id="why" class="py-24 relative overflow-hidden">
  {/* Decorative background elements */}
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full max-w-7xl h-px bg-gradient-to-r from-transparent via-heading/10 to-transparent"></div>
  <div class="absolute bottom-0 left-1/2 -translate-x-1/2 w-full max-w-7xl h-px bg-gradient-to-r from-transparent via-heading/10 to-transparent"></div>

  <div class="mx-auto max-w-7xl px-6 md:px-12 relative z-10">
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-8 md:gap-12">
      {
        whyItems.map((item, index) => (
          <div class="relative group text-center flex flex-col items-center justify-center p-8 rounded-3xl transition-all duration-300 hover:bg-secondary/5 border border-transparent hover:border-secondary/20">
            {/* Optional divider between columns on desktop */}
            {index !== 0 && (
              <div class="hidden lg:block absolute left-0 top-1/2 -translate-y-1/2 w-px h-16 bg-heading/10 group-hover:opacity-0 transition-opacity"></div>
            )}
            
            <div class="flex items-baseline justify-center mb-4">
              <span class="text-5xl md:text-6xl font-bold text-heading font-serif tracking-tight drop-shadow-sm transition-transform duration-300 group-hover:scale-105 group-hover:text-secondary">
                {item.value}
              </span>
              {item.unit && (
                <span class="ml-2 text-xl font-medium text-accent">
                  {item.unit}
                </span>
              )}
            </div>
            <p class="text-sm md:text-base font-medium text-body opacity-80 group-hover:opacity-100 transition-opacity max-w-[200px]">
              {item.description}
            </p>
          </div>
        ))
      }
    </div>
  </div>
</section>
