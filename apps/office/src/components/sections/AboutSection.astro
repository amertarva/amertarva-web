---
import { about } from '../../data/about'
---

<section id="about" class="py-24 md:py-32 relative overflow-hidden bg-base">
  <div class="mx-auto max-w-7xl px-6 md:px-12 relative z-10">
    <div class="flex flex-col lg:flex-row gap-16 lg:gap-24">
      {/* Sticky Header Content */}
      <div class="lg:w-5/12 lg:sticky lg:top-32 h-fit">
        <h2 class="text-3xl md:text-5xl font-bold font-serif text-heading leading-tight mb-6">
          {about.title}
        </h2>
        <div class="h-1 w-20 bg-secondary mb-8 rounded-full"></div>
        <p class="text-lg md:text-xl text-body leading-relaxed">
          {about.description}
        </p>
      </div>

      {/* Bento Grid Features */}
      <div class="lg:w-7/12 grid grid-cols-1 md:grid-cols-2 gap-6">
        {about.features.map((feature, index) => {
          const Icon = feature.icon;
          return (
            <div 
              class={`group p-8 rounded-3xl border border-heading/10 bg-heading/5 hover:bg-heading/10 transition-all duration-300 ${index === 1 || index === 3 ? 'md:translate-y-8' : ''}`}
            >
              <div class="w-14 h-14 rounded-2xl bg-secondary/15 text-secondary flex items-center justify-center mb-6 shadow-inner border border-secondary/20 group-hover:scale-110 transition-transform duration-300">
                <Icon class="w-7 h-7" />
              </div>
              <h3 class="text-xl font-bold text-heading mb-3">{feature.title}</h3>
              <p class="text-body leading-relaxed">{feature.description}</p>
            </div>
          );
        })}
      </div>
    </div>
  </div>
</section>
