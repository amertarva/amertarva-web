# Main Registry (Supabase Amertarva)
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=xxx

# Enkripsi — generate: openssl rand -hex 32
ENCRYPTION_KEY=

# JWT
JWT_SECRET=

# Server
PORT=3000
APP_URL=https://backend-amertarva.vercel.app
# Pisahkan dengan koma — production + localhost dev
# Production: amertarva.com (web), learning-amertarva.vercel.app (elearning)
# Dev: elearning:4321 | office:6789 | admin:5173 | web:4000 | cta:5000
CORS_ORIGIN=https://amertarva.com,https://www.amertarva.com,https://learning-amertarva.vercel.app,http://localhost:4321,http://localhost:6789,http://localhost:5173,http://localhost:4000,http://localhost:5000

# AI Integration
# Dapatkan API Key gratis di https://openrouter.ai/keys
OPENROUTER_API_KEY=